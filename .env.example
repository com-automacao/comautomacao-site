# Número de WhatsApp da Com Automação (formato internacional, só dígitos:
# 55 + DDD + número). Usado nos botões "Fale conosco" / FAB de WhatsApp.
# Defina no painel do host (ex.: Vercel → Settings → Environment Variables).
NEXT_PUBLIC_WHATSAPP_NUMBER=5515997133311

# URL final do site — base para Open Graph e canonical. Como o build é
# estático, isso é lido no momento do `npm run build`. Default: comautomacao.com
NEXT_PUBLIC_SITE_URL=https://comautomacao.com
